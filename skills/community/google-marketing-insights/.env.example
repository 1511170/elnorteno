# Google Marketing Insights — local secrets only. Do not commit real values.
# Use either GOOGLE_APPLICATION_CREDENTIALS or GOOGLE_SERVICE_ACCOUNT_JSON.

# Path relative to the site folder, for example: .secrets/google-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# Alternative: paste the full service account JSON as an environment secret, not in git.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Search Console property. Use the exact property URL or sc-domain property.
GSC_SITE_URL=https://elnorteno.com/

# GA4 numeric property ID, not the G- measurement ID.
GA4_PROPERTY_ID=

# Optional Google Ads preparation. Many Ads setups require OAuth refresh token instead of service account.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=
